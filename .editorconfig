# EditorConfig is awesome: https://editorconfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true

# 4 space indentation
[*.{js, py}]
indent_style = space
indent_size = 4

# Tab indentation for Makefiles scripts etc
[Makefile]
indent_style = tab

[*.{sh, bat}]
indent_style = tab

# Yaml uses spaces and smaller indent size
[*.yml]
indent_style = space
indent_size = 2
